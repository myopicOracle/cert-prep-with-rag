{
    "editor.fontSize": 15,
    "editor.formatOnSave": true,
    "geminicodeassist.enableTelemetry": false,
    "geminicodeassist.inlineSuggestions.enableAuto": false,
    "geminicodeassist.inlineSuggestions.suggestionSpeed": "Slow",
    "editor.inlineSuggest.experimental.suppressInlineSuggestions": "google.geminicodeassist",
    "editor.inlineSuggest.enabled": false,
    "geminicodeassist.chat.changeView": "Default diff view",
    "claudeCode.respectGitIgnore": false,
    "claudeCode.preferredLocation": "panel",
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        },
        "editor.maxTokenizationLineLength": 120,
        "editor.wordWrapColumn": 120
    },
    "ruff.lineLength": 120,
}